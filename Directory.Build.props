<Project>
  <!--
    Propriedades compartilhadas por todos os projetos da solução.
    Quality gate: warnings são tratados como erros (o build quebra em qualquer aviso),
    nullable habilitado e estilo de código verificado no build.
  -->
  <PropertyGroup>
    <LangVersion>latest</LangVersion>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <TreatWarningsAsErrors>true</TreatWarningsAsErrors>
    <EnforceCodeStyleInBuild>true</EnforceCodeStyleInBuild>
  </PropertyGroup>
</Project>
