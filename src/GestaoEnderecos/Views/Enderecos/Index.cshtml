@model GestaoEnderecos.Services.PaginaEnderecos
@{
    ViewData["Title"] = "Endereços";
    var temBusca = !string.IsNullOrEmpty(Model.Busca);
}

<div class="d-flex justify-content-between align-items-center mb-3 flex-wrap gap-2">
    <h1 class="h3 mb-0">Seus endereços</h1>
    <div class="d-flex gap-2">
        <a asp-action="Importar" class="btn btn-outline-secondary">⬆ Importar CSV</a>
        @if (Model.Total > 0)
        {
            <a asp-action="Exportar" class="btn btn-outline-secondary">⬇ Exportar CSV</a>
        }
        <a asp-action="Create" class="btn btn-primary">+ Adicionar</a>
    </div>
</div>

<form asp-action="Index" method="get" class="mb-3">
    <div class="input-group" style="max-width:480px">
        <input type="text" name="q" value="@Model.Busca" class="form-control"
               placeholder="Buscar por logradouro, cidade, bairro ou CEP…" />
        <button type="submit" class="btn btn-outline-secondary">Buscar</button>
        @if (temBusca)
        {
            <a asp-action="Index" class="btn btn-outline-secondary">Limpar</a>
        }
    </div>
</form>

@if (Model.Total == 0)
{
    <div class="text-center text-muted py-5 border rounded bg-light">
        @if (temBusca)
        {
            <p class="mb-0">Nenhum endereço encontrado para “@Model.Busca”.</p>
        }
        else
        {
            <p class="mb-3">Você ainda não cadastrou endereços.</p>
            <a asp-action="Create" class="btn btn-primary">Adicionar primeiro endereço</a>
        }
    </div>
}
else
{
    <div class="table-responsive">
        <table class="table table-hover align-middle">
            <thead>
                <tr>
                    <th>CEP</th>
                    <th>Logradouro</th>
                    <th>Nº</th>
                    <th>Complemento</th>
                    <th>Bairro</th>
                    <th>Cidade</th>
                    <th>UF</th>
                    <th class="text-end">Ações</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var e in Model.Itens)
                {
                    <tr>
                        <td>@Cep.Formatar(e.Cep)</td>
                        <td>@e.Logradouro</td>
                        <td>@e.Numero</td>
                        <td>@e.Complemento</td>
                        <td>@e.Bairro</td>
                        <td>@e.Cidade</td>
                        <td>@e.Uf</td>
                        <td class="text-end text-nowrap">
                            <a asp-action="Edit" asp-route-id="@e.Id" class="btn btn-sm btn-outline-primary">Editar</a>
                            <button type="button" class="btn btn-sm btn-outline-danger"
                                    data-bs-toggle="modal" data-bs-target="#modalExcluir"
                                    data-id="@e.Id" data-label="@e.Logradouro, @e.Numero">
                                Excluir
                            </button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <div class="d-flex justify-content-between align-items-center flex-wrap gap-2">
        <small class="text-muted">
            @Model.Total endereço(s) · página @Model.Pagina de @Model.TotalPaginas
        </small>
        @if (Model.TotalPaginas > 1)
        {
            <nav>
                <ul class="pagination pagination-sm mb-0">
                    <li class="page-item @(Model.Pagina <= 1 ? "disabled" : "")">
                        <a class="page-link" asp-action="Index" asp-route-q="@Model.Busca"
                           asp-route-pagina="@(Model.Pagina - 1)">Anterior</a>
                    </li>
                    <li class="page-item @(Model.Pagina >= Model.TotalPaginas ? "disabled" : "")">
                        <a class="page-link" asp-action="Index" asp-route-q="@Model.Busca"
                           asp-route-pagina="@(Model.Pagina + 1)">Próxima</a>
                    </li>
                </ul>
            </nav>
        }
    </div>
}

<div class="modal fade" id="modalExcluir" tabindex="-1" aria-hidden="true" data-delete-modal>
    <div class="modal-dialog">
        <div class="modal-content">
            <form method="post" asp-action="Delete" data-delete-action="@Url.Action("Delete")">
                <div class="modal-header">
                    <h5 class="modal-title">Excluir endereço</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Fechar"></button>
                </div>
                <div class="modal-body">
                    Tem certeza que deseja excluir <strong data-delete-target></strong>?
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                    <button type="submit" class="btn btn-danger">Excluir</button>
                </div>
            </form>
        </div>
    </div>
</div>
