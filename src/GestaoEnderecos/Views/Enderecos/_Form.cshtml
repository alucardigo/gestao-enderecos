@model EnderecoFormViewModel

<input type="hidden" asp-for="Id" />
<div asp-validation-summary="ModelOnly" class="text-danger small"></div>

<div class="row g-3">
    <div class="col-12 col-md-3">
        <label asp-for="Cep" class="form-label"></label>
        <input asp-for="Cep" id="cep" class="form-control" maxlength="9" autocomplete="off"
               inputmode="numeric" placeholder="00000-000" />
        <span asp-validation-for="Cep" class="text-danger small"></span>
        <div id="cepStatus" class="form-text"></div>
    </div>
    <div class="col-12 col-md-7">
        <label asp-for="Logradouro" class="form-label"></label>
        <input asp-for="Logradouro" id="logradouro" class="form-control" />
        <span asp-validation-for="Logradouro" class="text-danger small"></span>
    </div>
    <div class="col-6 col-md-2">
        <label asp-for="Numero" class="form-label"></label>
        <input asp-for="Numero" id="numero" class="form-control" />
        <span asp-validation-for="Numero" class="text-danger small"></span>
    </div>

    <div class="col-12 col-md-5">
        <label asp-for="Complemento" class="form-label"></label>
        <input asp-for="Complemento" id="complemento" class="form-control" />
        <span asp-validation-for="Complemento" class="text-danger small"></span>
    </div>
    <div class="col-12 col-md-4">
        <label asp-for="Bairro" class="form-label"></label>
        <input asp-for="Bairro" id="bairro" class="form-control" />
        <span asp-validation-for="Bairro" class="text-danger small"></span>
    </div>
    <div class="col-8 col-md-2">
        <label asp-for="Cidade" class="form-label"></label>
        <input asp-for="Cidade" id="cidade" class="form-control" />
        <span asp-validation-for="Cidade" class="text-danger small"></span>
    </div>
    <div class="col-4 col-md-1">
        <label asp-for="Uf" class="form-label"></label>
        <input asp-for="Uf" id="uf" class="form-control text-uppercase" maxlength="2" />
        <span asp-validation-for="Uf" class="text-danger small"></span>
    </div>
</div>
