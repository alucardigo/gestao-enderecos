@model AlterarSenhaViewModel
@{
    ViewData["Title"] = "Alterar senha";
}

<h1 class="h3 mb-3">Alterar senha</h1>

<div class="row">
    <div class="col-12 col-md-6">
        <form asp-action="AlterarSenha" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger small mb-2"></div>

            <div class="mb-3">
                <label asp-for="SenhaAtual" class="form-label"></label>
                <input asp-for="SenhaAtual" class="form-control" autocomplete="current-password" />
                <span asp-validation-for="SenhaAtual" class="text-danger small"></span>
            </div>
            <div class="mb-3">
                <label asp-for="NovaSenha" class="form-label"></label>
                <input asp-for="NovaSenha" class="form-control" autocomplete="new-password" />
                <span asp-validation-for="NovaSenha" class="text-danger small"></span>
            </div>
            <div class="mb-3">
                <label asp-for="ConfirmarNovaSenha" class="form-label"></label>
                <input asp-for="ConfirmarNovaSenha" class="form-control" autocomplete="new-password" />
                <span asp-validation-for="ConfirmarNovaSenha" class="text-danger small"></span>
            </div>

            <button type="submit" class="btn btn-primary">Alterar senha</button>
            <a asp-action="Perfil" class="btn btn-link">Cancelar</a>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
