@model ErrorViewModel
@{
    ViewData["Title"] = "Ops";
}
<div class="text-center mt-5">
    <h1 class="display-6">Ops, algo deu errado</h1>
    <p class="text-muted">Ocorreu um erro ao processar sua solicitação. Tente novamente.</p>
    @if (Model.ShowRequestId)
    {
        <p class="small text-muted">Código da requisição: <code>@Model.RequestId</code></p>
    }
    <a class="btn btn-primary" asp-controller="Enderecos" asp-action="Index">Voltar ao início</a>
</div>
