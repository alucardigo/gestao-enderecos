@model IReadOnlyList<Usuario>
@{
    ViewData["Title"] = "Usuários";
}

@if (TempData["Sucesso"] is string sucesso)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @sucesso
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Fechar"></button>
    </div>
}
@if (TempData["Erro"] is string erro)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        @erro
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Fechar"></button>
    </div>
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="h3 mb-0">Usuários</h1>
    <a asp-action="Create" class="btn btn-primary">+ Novo usuário</a>
</div>

<div class="table-responsive">
    <table class="table table-hover align-middle">
        <thead>
            <tr>
                <th>Nome</th>
                <th>Usuário</th>
                <th>Perfil</th>
                <th class="text-end">Ações</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var u in Model)
            {
                <tr>
                    <td>@u.Nome</td>
                    <td>@u.Login</td>
                    <td>
                        @if (u.IsAdmin)
                        {
                            <span class="badge text-bg-primary">Administrador</span>
                        }
                        else
                        {
                            <span class="badge text-bg-secondary">Usuário</span>
                        }
                    </td>
                    <td class="text-end text-nowrap">
                        <a asp-action="Edit" asp-route-id="@u.Id" class="btn btn-sm btn-outline-primary">Editar</a>
                        <a asp-action="RedefinirSenha" asp-route-id="@u.Id" class="btn btn-sm btn-outline-secondary">Senha</a>
                        <button type="button" class="btn btn-sm btn-outline-danger"
                                data-bs-toggle="modal" data-bs-target="#modalExcluir"
                                data-id="@u.Id" data-nome="@u.Nome">
                            Excluir
                        </button>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

<div class="modal fade" id="modalExcluir" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <form id="formExcluir" method="post" asp-action="Delete">
                <div class="modal-header">
                    <h5 class="modal-title">Excluir usuário</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Fechar"></button>
                </div>
                <div class="modal-body">
                    Excluir o usuário <strong id="nomeExcluir"></strong> e todos os seus endereços?
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                    <button type="submit" class="btn btn-danger">Excluir</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        const modalExcluir = document.getElementById('modalExcluir');
        modalExcluir?.addEventListener('show.bs.modal', function (event) {
            const botao = event.relatedTarget;
            document.getElementById('nomeExcluir').textContent = botao.getAttribute('data-nome');
            document.getElementById('formExcluir').action =
                '@Url.Action("Delete")/' + botao.getAttribute('data-id');
        });
    </script>
}
