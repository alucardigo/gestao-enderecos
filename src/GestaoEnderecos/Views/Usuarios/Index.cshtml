@model IReadOnlyList<Usuario>
@{
    ViewData["Title"] = "Usuários";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="h3 mb-0">Usuários</h1>
    <a asp-action="Create" class="btn btn-primary">+ Novo usuário</a>
</div>

<div class="table-responsive">
    <table class="table table-hover align-middle">
        <thead>
            <tr>
                <th>Nome</th>
                <th>Usuário</th>
                <th>Perfil</th>
                <th class="text-end">Ações</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var u in Model)
            {
                <tr>
                    <td>@u.Nome</td>
                    <td>@u.Login</td>
                    <td>
                        @if (u.IsAdmin)
                        {
                            <span class="badge bg-primary text-white">Administrador</span>
                        }
                        else
                        {
                            <span class="badge bg-secondary text-white">Usuário</span>
                        }
                    </td>
                    <td class="text-end text-nowrap">
                        <a asp-action="Edit" asp-route-id="@u.Id" class="btn btn-sm btn-outline-primary">Editar</a>
                        <a asp-action="RedefinirSenha" asp-route-id="@u.Id" class="btn btn-sm btn-outline-secondary">Senha</a>
                        <button type="button" class="btn btn-sm btn-outline-danger"
                                data-bs-toggle="modal" data-bs-target="#modalExcluir"
                                data-id="@u.Id" data-label="@u.Nome">
                            Excluir
                        </button>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

<div class="modal fade" id="modalExcluir" tabindex="-1" aria-hidden="true" data-delete-modal>
    <div class="modal-dialog">
        <div class="modal-content">
            <form method="post" asp-action="Delete" data-delete-action="@Url.Action("Delete")">
                <div class="modal-header">
                    <h5 class="modal-title">Excluir usuário</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Fechar"></button>
                </div>
                <div class="modal-body">
                    Excluir o usuário <strong data-delete-target></strong> e todos os seus endereços?
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                    <button type="submit" class="btn btn-danger">Excluir</button>
                </div>
            </form>
        </div>
    </div>
</div>
