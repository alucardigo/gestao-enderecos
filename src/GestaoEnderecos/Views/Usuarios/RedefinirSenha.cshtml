@model RedefinirSenhaViewModel
@{
    ViewData["Title"] = "Redefinir senha";
}

<h1 class="h3 mb-3">Redefinir senha</h1>
<p class="text-muted">Usuário: <strong>@Model.NomeUsuario</strong></p>

<div class="row">
    <div class="col-12 col-md-6">
        <form asp-action="RedefinirSenha" asp-route-id="@Model.Id" method="post">
            <input type="hidden" asp-for="Id" />
            <input type="hidden" asp-for="NomeUsuario" />
            <div asp-validation-summary="ModelOnly" class="text-danger small mb-2"></div>

            <div class="mb-3">
                <label asp-for="NovaSenha" class="form-label"></label>
                <input asp-for="NovaSenha" class="form-control" autocomplete="new-password" />
                <span asp-validation-for="NovaSenha" class="text-danger small"></span>
            </div>
            <div class="mb-3">
                <label asp-for="ConfirmarNovaSenha" class="form-label"></label>
                <input asp-for="ConfirmarNovaSenha" class="form-control" autocomplete="new-password" />
                <span asp-validation-for="ConfirmarNovaSenha" class="text-danger small"></span>
            </div>

            <button type="submit" class="btn btn-primary">Redefinir senha</button>
            <a asp-action="Index" class="btn btn-link">Cancelar</a>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
